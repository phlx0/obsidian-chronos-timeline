{
  "name": "obsidian-chronos-timeline",
  "version": "1.2.0",
  "description": "Visualize your Obsidian notes on an interactive timeline",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "timeline",
    "visualization",
    "pkm",
    "knowledge-management"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.3",
    "obsidian": "latest",
    "tslib": "^2.4.0",
    "typescript": "^4.7.4",
    "vitest": "^1.6.1"
  }
}
